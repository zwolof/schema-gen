#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
.DS_Store
.DS_Store.*

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
done

*.png
*.svg
csfloat_schema.json
# Dependency directories (remove the comment below to include it)
# vendor/

i_hate_valve/
i_hate_valve/*
web/*

# Build artefacts
bin/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
.vscode/
